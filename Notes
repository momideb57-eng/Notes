```react
import React, { useState, useEffect, useRef } from 'react';
import { 
  BookOpen, 
  Plus, 
  Moon, 
  Sun, 
  FileText, 
  Download, 
  Key, 
  Sparkles, 
  X, 
  ChevronRight, 
  ChevronLeft,
  AlertCircle, 
  Clock,
  BookMarked,
  Copy,
  Check
} from 'lucide-react';

// External script loading helper
const loadScript = (src) => {
  return new Promise((resolve, reject) => {
    if (document.querySelector(`script[src="${src}"]`)) {
      resolve();
      return;
    }
    const script = document.createElement('script');
    script.src = src;
    script.onload = () => resolve();
    script.onerror = () => reject();
    document.head.appendChild(script);
  });
};

export default function App() {
  // Theme & API Key states
  const [isDark, setIsDark] = useState(true);
  const [apiKey, setApiKey] = useState(() => localStorage.getItem('gemini_study_key') || '');
  const [showKeyInput, setShowKeyInput] = useState(!localStorage.getItem('gemini_study_key'));
  
  // App logic states
  const [notes, setNotes] = useState(() => {
    const saved = localStorage.getItem('study_notes_list');
    return saved ? JSON.parse(saved) : [];
  });
  const [selectedNote, setSelectedNote] = useState(null);
  
  // Mobile UI States: 'list' (shows guides) or 'reader' (shows current study note details)
  const [mobileView, setMobileView] = useState('list');
  const [copied, setCopied] = useState(false);
  
  // Upload & generation wizard states
  const [isModalOpen, setIsModalOpen] = useState(false);
  const [selectedFile, setSelectedFile] = useState(null);
  const [answerStyle, setAnswerStyle] = useState('point'); // 'point' or 'paragraph'
  const [isGenerating, setIsGenerating] = useState(false);
  const [progressMessage, setProgressMessage] = useState('');
  const [errorMessage, setErrorMessage] = useState('');
  
  // Rate limits
  const [uploadLimitCount, setUploadLimitCount] = useState(0);
  const [lastUploadDate, setLastUploadDate] = useState(() => localStorage.getItem('last_upload_date') || '');

  // Print/Download ref
  const documentRef = useRef(null);

  // Load styling libraries dynamically (html2pdf)
  useEffect(() => {
    loadScript('https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js')
      .catch(err => console.error('Failed to load html2pdf library', err));
  }, []);

  // Theme application
  useEffect(() => {
    if (isDark) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  }, [isDark]);

  // Persist notes list
  useEffect(() => {
    localStorage.setItem('study_notes_list', JSON.stringify(notes));
  }, [notes]);

  // Daily upload tracking check
  useEffect(() => {
    const today = new Date().toDateString();
    if (lastUploadDate === today) {
      setUploadLimitCount(1);
    } else {
      setUploadLimitCount(0);
    }
  }, [lastUploadDate]);

  // Handle API key saving
  const handleSaveApiKey = (e) => {
    e.preventDefault();
    const trimmed = apiKey.trim();
    if (trimmed) {
      localStorage.setItem('gemini_study_key', trimmed);
      setApiKey(trimmed);
      setShowKeyInput(false);
    }
  };

  // Convert File object to Base64
  const fileToBase64 = (file) => {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.readAsDataURL(file);
      reader.onload = () => {
        const base64String = reader.result.split(',')[1];
        resolve(base64String);
      };
      reader.onerror = (error) => reject(error);
    });
  };

  // Exponential backoff runner for API requests
  const callGeminiWithRetry = async (payload, retries = 5, delay = 1000) => {
    const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
    
    for (let i = 0; i < retries; i++) {
      try {
        const response = await fetch(url, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(payload)
        });

        if (response.ok) {
          return await response.json();
        }
        
        if (response.status === 429 || response.status >= 500) {
          await new Promise(res => setTimeout(res, delay));
          delay *= 2;
          continue;
        }

        const errData = await response.json();
        throw new Error(errData?.error?.message || `Request failed with status ${response.status}`);
      } catch (error) {
        if (i === retries - 1) throw error;
        await new Promise(res => setTimeout(res, delay));
        delay *= 2;
      }
    }
  };

  // Process and Generate Study Guide
  const handleGenerateStudyGuide = async () => {
    if (!apiKey) {
      setErrorMessage('Please configure a valid Gemini API key first.');
      return;
    }
    if (!selectedFile) {
      setErrorMessage('Please select a book PDF file to continue.');
      return;
    }

    // Check Limit (1 book per day limit)
    const today = new Date().toDateString();
    if (uploadLimitCount >= 1 && lastUploadDate === today) {
      setErrorMessage('Daily Limit Reached! You can only process 1 book PDF per day.');
      return;
    }

    setIsGenerating(true);
    setErrorMessage('');
    setProgressMessage('Reading book PDF content on your mobile device...');

    try {
      const base64Data = await fileToBase64(selectedFile);
      setProgressMessage('Sending PDF to Gemini-2.5-Flash...');

      const customPrompt = `
You are an expert academic educator. Analyze the uploaded PDF and generate a highly detailed and complete study companion guide.

The guide must contain the following structured sections, organized clearly with major Markdown headers:

# ${selectedFile.name.replace(/\.[^/.]+$/, "")} - Study Companion Guide

[STYLE PREFERENCE: Write all descriptive answers and guide elements primarily in **${answerStyle === 'point' ? 'bulleted/numbered point form with bold takeaways' : 'comprehensive paragraphs with detailed explanations'}**.]

---

## SECTION 1: Chapter-by-Chapter Core Notes
Provide extremely thorough, deep summaries of all core concepts, definitions, formulas, and important insights for EVERY chapter detected in the book.

---

## SECTION 2: 50 Multiple Choice Questions (MCQs)
Generate exactly 50 challenging, high-yield Multiple Choice Questions covering all sections of the book. 
Format each MCQ clearly:
- Question number
- Options (A, B, C, D)
- **Correct Answer** (indicated clearly)
- **Explanation/Rationale**

---

## SECTION 3: 10 Short-Answer Questions & Answers (2 Marks Each)
Provide exactly 10 short, conceptual questions with direct answers designed for exams (definitions or quick formulas).

---

## SECTION 4: 10 Analytical Questions & Answers (3 Marks Each)
Provide exactly 10 analytical, medium-length questions and answers (explaining principles, listing causes, outlining concepts).

---

## SECTION 5: 10 Comprehensive Questions & Answers (4 Marks Each)
Provide exactly 10 detailed questions and answers explaining intermediate systems or complex procedures.

---

## SECTION 6: 10 Essay/High-Value Questions & Answers (5 Marks Each)
Provide exactly 10 comprehensive essay-style questions with detailed, multi-layered answers. Outline key sections, list structural components, or design visual guides.

---

## SECTION 7: Solved Book Exercise Sections
Look up and extract all standard post-chapter questions, problems, and workbook exercises throughout the book, and provide standard, step-by-step solved answers for them.
`;

      const payload = {
        contents: [
          {
            parts: [
              {
                inlineData: {
                  mimeType: "application/pdf",
                  data: base64Data
                }
              },
              {
                text: customPrompt
              }
            ]
          }
        ]
      };

      setProgressMessage('Generating Notes, 50 MCQs, 40 Q&As, and Exercises. This can take up to 45 seconds...');
      
      const response = await callGeminiWithRetry(payload);
      const generatedText = response.candidates?.[0]?.content?.parts?.[0]?.text;

      if (!generatedText) {
        throw new Error('No content was generated. The PDF may be too large, encrypted, or unreadable.');
      }

      const newNote = {
        id: crypto.randomUUID(),
        title: selectedFile.name.replace(/\.[^/.]+$/, ""),
        date: new Date().toLocaleDateString('en-US', { day: 'numeric', month: 'short', year: 'numeric' }),
        content: generatedText,
        fileSize: (selectedFile.size / (1024 * 1024)).toFixed(2) + ' MB',
        style: answerStyle,
      };

      const updatedNotes = [newNote, ...notes];
      setNotes(updatedNotes);
      setSelectedNote(newNote);
      setMobileView('reader'); // Instantly slide over to read the generated note
      
      // Update limits
      const uploadDay = new Date().toDateString();
      localStorage.setItem('last_upload_date', uploadDay);
      setLastUploadDate(uploadDay);
      setUploadLimitCount(1);

      // Reset states
      setIsModalOpen(false);
      setSelectedFile(null);
      setProgressMessage('');
    } catch (err) {
      console.error(err);
      setErrorMessage(err.message || 'An error occurred. Try with a smaller or simpler file.');
    } finally {
      setIsGenerating(false);
    }
  };

  // Mobile Copy Utility (since mobile browsers sometimes block dynamic downloads)
  const copyToClipboard = () => {
    if (!selectedNote) return;
    const dummy = document.createElement("textarea");
    document.body.appendChild(dummy);
    dummy.value = selectedNote.content;
    dummy.select();
    document.execCommand("copy");
    document.body.removeChild(dummy);
    setCopied(true);
    setTimeout(() => setCopied(false), 2000);
  };

  // Download PDF
  const downloadPDF = () => {
    if (!selectedNote) return;
    setProgressMessage('Compiling PDF... please wait.');
    const element = documentRef.current;
    
    const opt = {
      margin:       10,
      filename:     `${selectedNote.title.replace(/\s+/g, '_')}_Study_Companion.pdf`,
      image:        { type: 'jpeg', quality: 0.98 },
      html2canvas:  { scale: 2, useCORS: true, logging: false },
      jsPDF:        { unit: 'mm', format: 'a4', orientation: 'portrait' },
      pagebreak:    { mode: ['avoid-all', 'css', 'legacy'] }
    };

    if (window.html2pdf) {
      window.html2pdf().from(element).set(opt).save()
        .then(() => setProgressMessage(''))
        .catch(err => {
          console.error(err);
          setProgressMessage('');
          alert("Error generating PDF. Try using the 'Copy' feature instead!");
        });
    } else {
      window.print();
    }
  };

  return (
    <div className="min-h-screen bg-slate-50 dark:bg-slate-950 text-slate-800 dark:text-slate-100 transition-colors duration-200 flex flex-col">
      
      {/* Top Mobile Navbar */}
      <header className="border-b border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 sticky top-0 z-40 px-4 py-3 flex items-center justify-between">
        <div className="flex items-center space-x-2">
          {mobileView === 'reader' && (
            <button 
              onClick={() => setMobileView('list')}
              className="p-2 -ml-2 rounded-xl text-slate-600 dark:text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800"
            >
              <ChevronLeft className="w-6 h-6" />
            </button>
          )}
          <div className="p-1.5 bg-indigo-600 rounded-lg text-white">
            <BookOpen className="w-5 h-5" />
          </div>
          <span className="font-bold tracking-tight text-base sm:text-lg">
            ExamPrep Mobile
          </span>
        </div>

        <div className="flex items-center space-x-2">
          {/* Theme Button */}
          <button 
            onClick={() => setIsDark(!isDark)}
            className="p-2 rounded-lg bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300"
            aria-label="Toggle theme"
          >
            {isDark ? <Sun className="w-4 h-4" /> : <Moon className="w-4 h-4" />}
          </button>

          {/* Setup Key */}
          <button 
            onClick={() => setShowKeyInput(!showKeyInput)}
            className={`p-2 rounded-lg ${apiKey ? 'text-slate-500 hover:text-indigo-500' : 'text-rose-500 animate-pulse'}`}
            title="Setup Gemini Key"
          >
            <Key className="w-4 h-4" />
          </button>
        </div>
      </header>

      {/* Main Responsive Body */}
      <main className="flex-1 max-w-lg w-full mx-auto p-3 sm:p-4 flex flex-col">
        
        {/* Mobile Key Warning Block */}
        {showKeyInput && (
          <div className="mb-4 bg-gradient-to-r from-pink-500/10 via-purple-500/10 to-indigo-500/10 border border-indigo-500/20 rounded-2xl p-4 space-y-3">
            <div className="space-y-1">
              <span className="px-2 py-0.5 bg-indigo-600/10 text-indigo-600 dark:text-indigo-400 text-[10px] font-bold rounded-md uppercase tracking-wider">Gemini Key Needed</span>
              <h2 className="text-sm font-bold">API Configuration</h2>
              <p className="text-xs text-slate-600 dark:text-slate-400">
                To parse books into notes, MCQs, and answers on mobile, insert your Gemini Pro key.
              </p>
            </div>
            <form onSubmit={handleSaveApiKey} className="flex flex-col gap-2">
              <input 
                type="password" 
                placeholder="Enter AI Studio API Key..."
                value={apiKey}
                onChange={(e) => setApiKey(e.target.value)}
                className="px-3 py-2 text-xs rounded-lg bg-white dark:bg-slate-900 border border-slate-300 dark:border-slate-700 focus:outline-none"
              />
              <button 
                type="submit"
                className="w-full py-2 bg-indigo-600 hover:bg-indigo-700 text-white font-bold text-xs rounded-lg"
              >
                Save Key
              </button>
            </form>
          </div>
        )}

        {/* View Toggle Controller */}
        {mobileView === 'list' ? (
          /* List View (Main Screen) */
          <div className="space-y-4 flex-1 flex flex-col">
            
            {/* Limit Warning */}
            <div className="flex items-center justify-between text-[11px] bg-slate-100 dark:bg-slate-900 p-2.5 rounded-xl border border-slate-200 dark:border-slate-800">
              <span className="flex items-center space-x-1.5 text-slate-500">
                <Clock className="w-3.5 h-3.5" />
                <span>Today's Limit:</span>
              </span>
              <span className="font-bold text-indigo-600 dark:text-indigo-400">{uploadLimitCount}/1 Uploaded</span>
            </div>

            {/* Large Tappable Plus Button */}
            <button 
              onClick={() => {
                if (!apiKey) {
                  setShowKeyInput(true);
                  return;
                }
                setIsModalOpen(true);
              }}
              className="w-full p-4 bg-indigo-600 hover:bg-indigo-700 text-white rounded-2xl shadow-lg shadow-indigo-600/20 flex items-center justify-center space-x-2 font-bold text-sm min-h-[50px]"
            >
              <Plus className="w-5 h-5" />
              <span>Upload Book PDF</span>
            </button>

            {/* List Header */}
            <div className="flex items-center justify-between pt-2">
              <h3 className="font-bold text-xs uppercase tracking-wider text-slate-400 dark:text-slate-500 flex items-center space-x-2">
                <BookMarked className="w-4 h-4 text-indigo-500" />
                <span>Processed Guides ({notes.length})</span>
              </h3>
            </div>

            {/* Notes List Content */}
            {notes.length === 0 ? (
              <div className="flex-1 flex flex-col items-center justify-center text-center p-6 border-2 border-dashed border-slate-200 dark:border-slate-800 rounded-3xl min-h-[250px] space-y-3">
                <div className="p-3 bg-slate-100 dark:bg-slate-900 rounded-full text-slate-400 dark:text-slate-600">
                  <FileText className="w-8 h-8" />
                </div>
                <div>
                  <h4 className="font-bold text-xs">No study notes available</h4>
                  <p className="text-[11px] text-slate-500 max-w-xs mt-1">
                    Tap the upload button above to select your PDF textbook and generate custom revision kits.
                  </p>
                </div>
              </div>
            ) : (
              <div className="space-y-2">
                {notes.map((note) => (
                  <button
                    key={note.id}
                    onClick={() => {
                      setSelectedNote(note);
                      setMobileView('reader');
                    }}
                    className="w-full text-left p-4 rounded-xl border border-slate-200 dark:border-slate-800 bg-white dark:bg-slate-900 flex items-center justify-between"
                  >
                    <div className="space-y-1 pr-3 truncate">
                      <div className="font-bold text-xs truncate text-slate-800 dark:text-slate-100">
                        {note.title}
                      </div>
                      <div className="text-[10px] text-slate-500 dark:text-slate-400 flex items-center space-x-2">
                        <span className="capitalize">{note.style} Form</span>
                        <span>•</span>
                        <span>{note.date}</span>
                      </div>
                    </div>
                    <ChevronRight className="w-4 h-4 text-slate-400 shrink-0" />
                  </button>
                ))}
              </div>
            )}
          </div>
        ) : (
          /* Reader View (Full Companion Details) */
          <div className="space-y-3 flex-1 flex flex-col h-full bg-white dark:bg-slate-900 rounded-2xl border border-slate-200 dark:border-slate-800 overflow-hidden">
            
            {/* Floating Action Controls */}
            <div className="p-3 border-b border-slate-200 dark:border-slate-800 flex items-center justify-between gap-2 bg-slate-50 dark:bg-slate-900/50">
              <button 
                onClick={() => setMobileView('list')}
                className="px-3 py-1.5 rounded-lg border border-slate-200 dark:border-slate-700 text-xs font-semibold"
              >
                Back
              </button>

              <div className="flex items-center space-x-1">
                {/* Mobile Copy Option */}
                <button 
                  onClick={copyToClipboard}
                  className="p-2 text-slate-500 hover:text-indigo-500 hover:bg-slate-100 dark:hover:bg-slate-800 rounded-lg"
                  title="Copy Text to clipboard"
                >
                  {copied ? <Check className="w-4 h-4 text-emerald-500" /> : <Copy className="w-4 h-4" />}
                </button>

                {/* PDF export */}
                <button 
                  onClick={downloadPDF}
                  className="flex items-center space-x-1.5 px-3 py-1.5 bg-indigo-600 hover:bg-indigo-700 text-white rounded-lg text-xs font-bold"
                >
                  <Download className="w-3.5 h-3.5" />
                  <span>PDF</span>
                </button>

                {/* Delete */}
                <button 
                  onClick={() => {
                    if (confirm("Delete this guide?")) {
                      const filtered = notes.filter(n => n.id !== selectedNote.id);
                      setNotes(filtered);
                      setSelectedNote(null);
                      setMobileView('list');
                    }
                  }}
                  className="p-2 text-rose-500"
                >
                  <X className="w-4 h-4" />
                </button>
              </div>
            </div>

            {/* Note Progress Status Bar */}
            {progressMessage && (
              <div className="mx-4 p-2 bg-indigo-500/10 text-indigo-700 dark:text-indigo-400 text-[10px] rounded-lg border border-indigo-500/20 font-medium">
                {progressMessage}
              </div>
            )}

            {/* Clean Mobile Reader Container */}
            <div className="p-4 overflow-y-auto max-h-[60vh] flex-1">
              <article 
                ref={documentRef} 
                className="prose prose-slate dark:prose-invert max-w-none text-xs leading-relaxed"
              >
                <div className="space-y-4">
                  {selectedNote.content.split('\n').map((line, idx) => {
                    if (line.startsWith('# ')) {
                      return <h1 key={idx} className="text-lg font-bold text-slate-900 dark:text-white pb-1 border-b border-indigo-500/20 mt-4 first:mt-0">{line.replace('# ', '')}</h1>;
                    }
                    if (line.startsWith('## ')) {
                      return <h2 key={idx} className="text-sm font-bold text-slate-900 dark:text-white pt-4 pb-1 border-b border-slate-200 dark:border-slate-800">{line.replace('## ', '')}</h2>;
                    }
                    if (line.startsWith('### ')) {
                      return <h3 key={idx} className="text-xs font-bold text-slate-800 dark:text-slate-200 pt-3">{line.replace('### ', '')}</h3>;
                    }
                    if (line.startsWith('- ') || line.startsWith('* ')) {
                      return (
                        <li key={idx} className="ml-4 list-disc text-slate-700 dark:text-slate-300 my-0.5">
                          {formatTextEmphasis(line.substring(2))}
                        </li>
                      );
                    }

                    const numListMatch = line.match(/^\d+\.\s(.*)/);
                    if (numListMatch) {
                      return (
                        <li key={idx} className="ml-4 list-decimal text-slate-700 dark:text-slate-300 my-0.5">
                          {formatTextEmphasis(numListMatch[1])}
                        </li>
                      );
                    }

                    if (line.trim() === '---') {
                      return <hr key={idx} className="my-4 border-slate-200 dark:border-slate-800" />;
                    }
                    if (line.trim() === '') return <div key={idx} className="h-1"></div>;
                    
                    return (
                      <p key={idx} className="text-slate-700 dark:text-slate-300 my-1">
                        {formatTextEmphasis(line)}
                      </p>
                    );
                  })}
                </div>
              </article>
            </div>
          </div>
        )}

      </main>

      {/* Touch-optimized PDF Upload Configuration Modal */}
      {isModalOpen && (
        <div className="fixed inset-0 z-50 overflow-y-auto flex items-end sm:items-center justify-center p-0 sm:p-4 bg-slate-950/85">
          <div className="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 w-full sm:max-w-md rounded-t-3xl sm:rounded-2xl overflow-hidden shadow-2xl transition-all flex flex-col relative pb-6 sm:pb-0">
            
            {/* Modal Header */}
            <div className="p-4 border-b border-slate-100 dark:border-slate-800 flex items-center justify-between">
              <div>
                <h3 className="text-sm font-bold">Companion Configuration</h3>
                <p className="text-[10px] text-slate-400">Limit: 1 upload per day</p>
              </div>
              <button 
                onClick={() => setIsModalOpen(false)}
                className="p-1.5 rounded-lg text-slate-400 hover:bg-slate-100 dark:hover:bg-slate-800"
              >
                <X className="w-5 h-5" />
              </button>
            </div>

            {/* Modal Body */}
            <div className="p-4 space-y-4 max-h-[70vh] overflow-y-auto">
              
              {uploadLimitCount >= 1 && (
                <div className="p-3 bg-amber-500/10 text-amber-700 dark:text-amber-400 rounded-xl text-xs flex items-start space-x-1.5 border border-amber-500/20">
                  <AlertCircle className="w-4 h-4 shrink-0 mt-0.5" />
                  <span>Limit reached. You can generate another study guide tomorrow.</span>
                </div>
              )}

              {errorMessage && (
                <div className="p-3 bg-rose-500/10 text-rose-600 dark:text-rose-400 rounded-xl text-xs flex items-start space-x-1.5 border border-rose-500/20">
                  <AlertCircle className="w-4 h-4 shrink-0" />
                  <span>{errorMessage}</span>
                </div>
              )}

              {/* PDF Selector Block */}
              <div className="space-y-1.5">
                <label className="block text-xs font-bold text-slate-500">
                  1. Select Textbook / Book PDF
                </label>
                <div className="border-2 border-dashed border-slate-200 dark:border-slate-800 rounded-xl p-4 text-center hover:border-indigo-500 bg-slate-50/50 dark:bg-slate-900/50 relative">
                  <input 
                    type="file" 
                    accept="application/pdf"
                    onChange={(e) => {
                      if(e.target.files && e.target.files[0]) {
                        setSelectedFile(e.target.files[0]);
                      }
                    }}
                    className="absolute inset-0 w-full h-full opacity-0 cursor-pointer"
                    disabled={isGenerating}
                  />
                  <div className="flex flex-col items-center space-y-1">
                    <FileText className="w-7 h-7 text-indigo-500" />
                    {selectedFile ? (
                      <p className="text-xs font-bold text-slate-800 dark:text-slate-200 truncate max-w-[220px]">
                        {selectedFile.name}
                      </p>
                    ) : (
                      <p className="text-xs text-slate-500">Tap to browse book file</p>
                    )}
                  </div>
                </div>
              </div>

              {/* Formatting Selector Block */}
              <div className="space-y-2">
                <label className="block text-xs font-bold text-slate-500">
                  2. Choose Answer Format
                </label>
                <div className="grid grid-cols-2 gap-2">
                  <button
                    type="button"
                    onClick={() => setAnswerStyle('point')}
                    className={`p-3 rounded-xl border text-left flex flex-col space-y-1 transition ${
                      answerStyle === 'point' 
                        ? 'border-indigo-500 bg-indigo-500/10' 
                        : 'border-slate-200 dark:border-slate-800 bg-transparent'
                    }`}
                  >
                    <span className="font-bold text-xs">Point Form</span>
                    <span className="text-[10px] text-slate-400">Bulleted, structured points.</span>
                  </button>

                  <button
                    type="button"
                    onClick={() => setAnswerStyle('paragraph')}
                    className={`p-3 rounded-xl border text-left flex flex-col space-y-1 transition ${
                      answerStyle === 'paragraph' 
                        ? 'border-indigo-500 bg-indigo-500/10' 
                        : 'border-slate-200 dark:border-slate-800 bg-transparent'
                    }`}
                  >
                    <span className="font-bold text-xs">Paragraphs</span>
                    <span className="text-[10px] text-slate-400">Explanatory textual blocks.</span>
                  </button>
                </div>
              </div>

              {/* Mobile Processing Box */}
              {isGenerating && (
                <div className="space-y-2 p-3 bg-indigo-600/5 rounded-xl border border-indigo-500/10">
                  <div className="flex items-center justify-between text-[11px] font-bold text-indigo-500">
                    <span>AI Engine Active</span>
                    <span>Processing...</span>
                  </div>
                  <p className="text-[10px] text-slate-400 italic">
                    {progressMessage}
                  </p>
                </div>
              )}

            </div>

            {/* Modal Bottom Actions */}
            <div className="p-4 bg-slate-50 dark:bg-slate-900 border-t border-slate-100 dark:border-slate-800 flex items-center justify-end space-x-2">
              <button
                type="button"
                onClick={() => setIsModalOpen(false)}
                className="px-4 py-2 rounded-lg border border-slate-200 dark:border-slate-700 text-xs font-bold text-slate-600 dark:text-slate-300"
                disabled={isGenerating}
              >
                Close
              </button>
              <button
                type="button"
                onClick={handleGenerateStudyGuide}
                disabled={isGenerating || !selectedFile || uploadLimitCount >= 1}
                className={`px-5 py-2 rounded-lg text-xs font-bold text-white ${
                  isGenerating || !selectedFile || uploadLimitCount >= 1
                    ? 'bg-slate-400 cursor-not-allowed'
                    : 'bg-indigo-600 hover:bg-indigo-700 shadow-lg'
                }`}
              >
                {isGenerating ? 'Analyzing...' : 'Assemble'}
              </button>
            </div>

          </div>
        </div>
      )}

      {/* Footer */}
      <footer className="py-4 px-4 text-center border-t border-slate-200 dark:border-slate-800 text-[10px] text-slate-500 shrink-0">
        <p>© 2026 ExamPrep AI. Optimized for Mobile.</p>
      </footer>

    </div>
  );
}

// Inline Bold styling helper for Markdown formatting inside native render
function formatTextEmphasis(text) {
  if (!text) return "";
  const parts = [];
  let currentIdx = 0;
  
  const regex = /\*\*(.*?)\*\*/g;
  let match;
  
  while ((match = regex.exec(text)) !== null) {
    if (match.index > currentIdx) {
      parts.push(text.substring(currentIdx, match.index));
    }
    parts.push(<strong key={match.index} className="font-extrabold text-slate-900 dark:text-white">{match[1]}</strong>);
    currentIdx = regex.lastIndex;
  }
  
  if (currentIdx < text.length) {
    parts.push(text.substring(currentIdx));
  }
  
  return parts.length > 0 ? <>{parts}</> : text;
}

```
